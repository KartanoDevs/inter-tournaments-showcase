# ============================================================
# PLANTILLA DE VARIABLES DE ENTORNO DE PRODUCCIÓN
# ============================================================
# 1. Copia este archivo: cp .env.production.example .env.production
# 2. Rellena los valores reales
# 3. NUNCA subas .env.production al repositorio Git
# 4. Transfiere al servidor vía: scp .env.production usuario@<IP>:/ruta/proyecto/backend/
# ============================================================

# Puerto del servidor Express
PORT=3000

# Entorno de ejecución
NODE_ENV=production

# Conexión a la base de datos PostgreSQL
# El hostname "db" resuelve al contenedor de postgres dentro de la red Docker
DATABASE_URL=postgresql://<POSTGRES_USER>:<POSTGRES_PASSWORD>@db:5432/<POSTGRES_DB>?schema=public

# Variables individuales de Postgres (las usa el servicio "db" en docker-compose)
POSTGRES_USER=<usuario_postgres>
POSTGRES_PASSWORD=<contraseña_segura_postgres>
POSTGRES_DB=<nombre_base_de_datos>

# Clave secreta para firmar tokens JWT — usa al menos 64 caracteres aleatorios
# Genera una con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=<clave_secreta_jwt_muy_larga_y_aleatoria>

# Tiempo de expiración del token JWT
JWT_EXPIRES_IN=7d

# Orígenes permitidos por CORS (dominio o IP de tu servidor Oracle)
# Ejemplo con IP: http://123.456.789.012
# Ejemplo con dominio: https://interauu.com,https://www.interauu.com
ALLOWED_ORIGINS=http://<IP_O_DOMINIO_ORACLE>

# ============================================================
# Dropbox — backup automático de snapshots (OPCIONAL)
# Dejar las 3 primeras vacías para desactivar la subida a Dropbox.
# Setup completo en PASOS_DROPBOX_BACKUP.md
# ============================================================

# App key y App secret de la app creada en https://www.dropbox.com/developers/apps
DROPBOX_APP_KEY=
DROPBOX_APP_SECRET=

# Refresh token permanente (no caduca). Se genera una sola vez con el flujo OAuth
# (ver PASOS_DROPBOX_BACKUP.md). Renueva el access token automáticamente.
DROPBOX_REFRESH_TOKEN=

# Carpeta raíz dentro de Dropbox donde se guardan los backups (debe empezar por "/").
# Dentro se crea una subcarpeta por torneo automáticamente.
DROPBOX_BACKUP_FOLDER=/Backups Torneo Inter AUU
